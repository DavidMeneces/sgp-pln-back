										"packages": {},
										"requests": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test(\"Status Success\", () => {\r",
											"    pm.expect(pm.response.json()).to.have.property('value')\r",
											"    pm.expect(pm.response.json().value).to.be.a('string')\r",
											"    pm.collectionVariables.set('id_ingredient', pm.response.json().value)\r",
											"});\r",
											"pm.test(\"Create ingredient\", () => {\r",
											"    pm.expect(pm.response.json()).to.have.property('value')\r",
											"    pm.expect(pm.response.json().value).to.be.a('string')\r",
											"    pm.collectionVariables.set('id_ingredient', pm.response.json().value)\r",
											"});\r",
											"//update index\r",
											"let index = parseInt(pm.collectionVariables.get(\"ingredient_index\"));\r",
											"pm.collectionVariables.set(\"ingredient_index\", index + 1);"

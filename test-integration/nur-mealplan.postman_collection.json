											"pm.collectionVariables.set(\"ingredient_name\", item.name);\r",
											"pm.collectionVariables.set(\"ingredient_description\", item.description);\r",
											"pm.collectionVariables.set(\"ingredient_unit_measure\", item.unitMeasure);\r",
											"pm.collectionVariables.set(\"ingredient_calories_per_gram\", item.caloriesPerGram);"
										],
